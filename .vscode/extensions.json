{
  // Workspace extension recommendations — https://go.microsoft.com/fwlink/?LinkId=827846
  // Format: ${publisher}.${name}. Curated to match the tooling this project actually uses;
  // module-specific entries are gated on the same answers that scaffold those modules.
  // JSONC (comments + trailing commas); excluded from the check-json hook for that reason.
  "recommendations": [
    // Language-agnostic — useful in any project generated from this template.
    "aaron-bond.better-comments", // color-coded comment tags (TODO/FIXME/…)
    "gruntfuggly.todo-tree", // tree view of those tags
    "nhoizey.gremlins", // surface invisible / zero-width characters
    "tekumara.typos-vscode", // typo catcher (pairs with the typos hook)
    "tyriar.sort-lines", // sort selected lines
    "tamasfe.even-better-toml", // TOML (pyproject.toml, .config/*.toml)
    "redhat.vscode-yaml", // YAML (pre-commit, CI, …)
    "editorconfig.editorconfig", // apply .editorconfig rules live
    "vivaxy.vscode-conventional-commits", // guided conventional-commit messages
    "rvben.rumdl", // Markdown linter/formatter (matches the rumdl hook)
    "codezombiech.gitignore", // pull canonical .gitignore templates
    "mechatroner.rainbow-csv", // CSV column coloring
    // Python
    "charliermarsh.ruff", // ruff lint + format
    "ms-python.python", // Python language support
    "njpwerner.autodocstring", // generate docstrings
  ],
  "unwantedRecommendations": []
}
